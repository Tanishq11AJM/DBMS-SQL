# Design a trigger to stop insertion or updation in the table for the days like sat or sun of any date ( for practice purpose take the day as 'tue')
Shortcut -> CREATE OR REPLACE TRIGGER no_ins_upd
(AS) declare
    v_day VARCHAR2(10);
BEGIN
    v_day :=TO_CHAR(SYSDATE, 'DAY');
    IF v_day = 'TUESDAY' THEN
        RAISE_APPLICATION_ERROR(-20001, 'Insertion or Updation is not allowed on ' || v_day);
    END IF;
END;
/


#Actual code
CREATE OR REPLACE TRIGGER check_day
BEFORE INSERT OR UPDATE ON emp2
FOR EACH ROW
DECLARE
 v_day VARCHAR2(10);
 BEGIN
 v_day := UPPER(TRIM(TO_CHAR(SYSDATE, 'DAY')));
IF v_day = 'TUESDAY' THEN
RAISE_APPLICATION_ERROR(-20001,'Insertion or Updation is not allowed on Tuesday');
END IF;
END;
/
