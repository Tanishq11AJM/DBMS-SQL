create or replace procedure to_mnth
as
v_month varchar2(10);
begin
v_month:=to_char(sysdate, 'mon');
dbms_output.put_line('the current month is ' || v_month);
end;
/
set serveroutput on
exec to_mnth;
output: the current month is mar


